# ── Database ──────────────────────────────────────────────────────────────────
# Local dev — connect to a local or Docker PostgreSQL instance
DATABASE_URL="postgresql://myfi:changeme@localhost:5432/myfi"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# ── Domain (used by Traefik and NextAuth) ─────────────────────────────────────
DOMAIN="myfi.yourdomain.com"

# ── Docker PostgreSQL password ────────────────────────────────────────────────
DB_PASSWORD="changeme"

# ── First admin account (created on first boot) ───────────────────────────────
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="changeme123"

# ── AI providers (optional — leave blank to disable) ──────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ── SMTP ingest (optional) ────────────────────────────────────────────────────
SMTP_PORT=2525
