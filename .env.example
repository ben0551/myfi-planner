# ── Database ──────────────────────────────────────────────────────────────────
# Local dev — connect to a local or Docker PostgreSQL instance
DATABASE_URL="postgresql://myfi:changeme@localhost:5432/myfi"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# ── Domain (used by Traefik and NextAuth) ─────────────────────────────────────
DOMAIN="myfi.yourdomain.com"

# ── Docker PostgreSQL password ────────────────────────────────────────────────
DB_PASSWORD="changeme"

# ── First admin account (created on first boot) ───────────────────────────────
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="changeme123"

# ── AI providers (optional — leave blank to disable) ──────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ── SMTP ingest (optional) ────────────────────────────────────────────────────
SMTP_PORT=2525

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Microsoft OAuth (optional — leave blank to disable) ──────────────────────
# 1. Go to https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# 2. New registration → Web → Redirect URI: https://yourdomain.com/api/auth/callback/microsoft-entra-id
# 3. Create a client secret under Certificates & secrets
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"   # use "common" for any Microsoft account, or your tenant ID for org-only

# ── Outbound SMTP for password reset emails (optional) ───────────────────────
# If not set, admins can still send reset links manually from User Management
SMTP_HOST=""
SMTP_FROM=""
SMTP_USER=""
SMTP_PASS=""
# SMTP_SEND_PORT=587
