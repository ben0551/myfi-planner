# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (file path relative to prisma/)
DATABASE_URL="file:./dev.db"
# For Docker (set automatically in docker-compose.yml — no need to change)
# DATABASE_URL="file:/app/data/prod.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# ── Domain (used by Traefik labels and NextAuth) ──────────────────────────────
DOMAIN="myfi.yourdomain.com"

# ── First admin account (created on first boot) ───────────────────────────────
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="changeme123"

# ── AI providers (optional — leave blank to disable) ──────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ── SMTP ingest (optional) ────────────────────────────────────────────────────
SMTP_PORT=2525
